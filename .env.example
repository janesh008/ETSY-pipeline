# =============================================================
# Etsy Pipeline — Environment Variables
# =============================================================
# Copy this file to `.env` and fill in your values.
# Never commit the actual `.env` file to version control.
# =============================================================

# --- Authentication Mode ---
# Set to True to use Vertex AI with Application Default Credentials (GCP)
# Set to False to use Google AI API key (AI Studio)
USE_VERTEX_AI=True

# --- Google AI API key (only used when USE_VERTEX_AI=False) ---
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-api-key-here

# --- GCP / Vertex AI Settings (required when USE_VERTEX_AI=True) ---
# Your GCP project ID
GCP_PROJECT_ID=your-gcp-project-id
# GCP region for Vertex AI
GCP_LOCATION=us-central1

# GCS Bucket (for future Cloud Storage)
GCS_BUCKET=your-gcs-bucket-name

# Gemini model name
GEMINI_MODEL=gemini-2.5-flash

# Output root directory for pipeline results
OUTPUT_ROOT=./output

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
