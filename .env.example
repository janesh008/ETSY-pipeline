# =============================================================
# Etsy Pipeline — Environment Variables (Template)
# =============================================================
# Copy this file to `.env` and fill in your values.
# =============================================================

# --- GCP / Vertex AI Settings ---
# Your GCP project ID
GCP_PROJECT_ID=your-gcp-project-id
# GCP region for Vertex AI
GCP_LOCATION=us-central1

# (Optional) Local path to Google Drive Service Account credentials JSON file.
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=path/to/credentials.json

# --- Google Drive Settings ---
# Folder ID of the shared Google Drive folder where prompts will be saved
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# --- GCS Bucket (for future Cloud Storage) ---
GCS_BUCKET=your-gcs-bucket-name

# Gemini model name
GEMINI_MODEL=gemini-2.5-flash

# Output root directory for pipeline results
OUTPUT_ROOT=./output

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
