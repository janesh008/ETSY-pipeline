# =============================================================
# Etsy Pipeline — Environment Variables (Template)
# =============================================================
# Copy this file to `.env` and fill in your values.
# =============================================================

# --- GCP / Vertex AI Settings ---
# Your GCP project ID
GCP_PROJECT_ID=your-gcp-project-id
# GCP region for Vertex AI
GCP_LOCATION=us-central1

# --- Google Drive Settings ---
# Local path to your Google Drive OAuth 2.0 client credentials JSON file
GOOGLE_DRIVE_CLIENT_SEC_JSON=cred/client_secret.json

# Local path where the login session token will be saved
GOOGLE_DRIVE_TOKEN_JSON=cred/token.json
# Folder ID of the shared Google Drive folder where prompts will be saved
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# --- GCS Bucket (for future Cloud Storage) ---
GCS_BUCKET=your-gcs-bucket-name

# Gemini model name
GEMINI_MODEL=gemini-2.5-flash

# Output root directory for pipeline results
OUTPUT_ROOT=./output

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# --- Etsy Open API v3 Settings ---
ETSY_KEYSTRING=s9ido8gpuc6tbtvzcchl1s4z
ETSY_SHARED_SECRET=h9hjnw214t
ETSY_SHOP_ID=66082828
ETSY_ACCESS_TOKEN=
ETSY_REFRESH_TOKEN=
DEFAULT_LISTING_PRICE=5.99
DEFAULT_LISTING_QUANTITY=999

# =============================================================
# CraftDesk API — New SaaS Platform Settings
# =============================================================

# --- PostgreSQL (Neon.tech) ---
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/craftdesk?sslmode=require

# --- JWT Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Fernet AES-256 Encryption ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# --- App ---
DEBUG=false
